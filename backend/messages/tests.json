{
  "tests": [
    {
      "name": "Inbox without auth",
      "method": "GET",
      "path": "/?action=inbox",
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Send without auth",
      "method": "POST",
      "path": "/?action=send",
      "body": {"receiver_id": 1, "text": "hello"},
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Reviews list with user_id",
      "method": "GET",
      "path": "/?action=reviews_list&user_id=1",
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    }
  ]
}