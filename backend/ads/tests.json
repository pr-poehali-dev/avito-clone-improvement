{
  "tests": [
    {
      "name": "List ads (public)",
      "method": "GET",
      "path": "/?action=list",
      "expectedStatus": 200,
      "expectedBody": {"total": 1},
      "bodyMatcher": "partial"
    },
    {
      "name": "Get ad - not found",
      "method": "GET",
      "path": "/?action=get&id=999999",
      "expectedStatus": 404,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Create ad without auth",
      "method": "POST",
      "path": "/?action=create",
      "body": {"title": "Test", "category": "electronics", "price": 1000},
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "My ads without auth",
      "method": "GET",
      "path": "/?action=my",
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Delete without auth",
      "method": "POST",
      "path": "/?action=delete",
      "body": {"id": 1},
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Site stats",
      "method": "GET",
      "path": "/?action=site_stats",
      "expectedStatus": 200,
      "expectedBody": {"total_ads": 1, "total_users": 2, "total_cities": 2, "total_deals": 0},
      "bodyMatcher": "partial"
    },
    {
      "name": "Notifications without auth",
      "method": "GET",
      "path": "/?action=notifications",
      "expectedStatus": 200,
      "expectedBody": {"notifications": [], "unread_count": 0},
      "bodyMatcher": "partial"
    },
    {
      "name": "Viewed ids without auth",
      "method": "GET",
      "path": "/?action=viewed_ids",
      "expectedStatus": 200,
      "expectedBody": {"ids": []},
      "bodyMatcher": "partial"
    },
    {
      "name": "View history without auth",
      "method": "GET",
      "path": "/?action=view_history",
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Offer price without auth",
      "method": "POST",
      "path": "/?action=offer_price",
      "body": {"ad_id": 1, "offered_price": 500},
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Ad view stats without auth",
      "method": "GET",
      "path": "/?action=ad_view_stats&ad_id=1",
      "expectedStatus": 401,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    }
  ]
}